# ==============================================================
# ln-ai-network — Environment Template (SAFE TO COMMIT)
#
# ✅ Commit THIS file to Git as ".env.example"
# ❌ Do NOT commit ".env" — it contains your real secrets
#
# Setup:
#   cp .env.example .env
#   # Edit .env and paste in your real API keys
#   source env.sh
# ==============================================================


############################################
# LLM Provider Selection
############################################
# Supported: openai | ollama | gemini | claude
ALLOW_LLM=1
LLM_BACKEND=openai


############################################
# Claude / Anthropic Settings
############################################
# Get your key at: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=__REPLACE_WITH_REAL_KEY__

# Model to use
CLAUDE_MODEL=claude-opus-4-6


############################################
# OpenAI Settings
############################################
OPENAI_API_KEY=__REPLACE_WITH_REAL_KEY__
OPENAI_MODEL=gpt-4o
OPENAI_TIMEOUT_S=60


############################################
# Gemini Settings
############################################
GEMINI_API_KEY=__REPLACE_WITH_REAL_KEY__
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_S=180


############################################
# Ollama Settings (Local — no API key needed)
############################################
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_SEC=120


############################################
# Pipeline Stage Overrides (optional)
############################################
# Override backend or model per stage — leave commented unless needed
# TRANSLATOR_LLM_BACKEND=claude
# PLANNER_LLM_BACKEND=claude
# TRANSLATOR_CLAUDE_MODEL=claude-opus-4-6
# PLANNER_CLAUDE_MODEL=claude-opus-4-6
# TRANSLATOR_OPENAI_MODEL=gpt-4o-mini
# PLANNER_OPENAI_MODEL=gpt-4o
# TRANSLATOR_OLLAMA_MODEL=llama3.2:3b
# PLANNER_OLLAMA_MODEL=llama3.1:8b


############################################
# Agent Cadence / Control Plane
############################################
AGENT_TICK_MS=500
LLM_MIN_INTERVAL_MS=1000
LLM_MAX_IN_FLIGHT=1


############################################
# Rate Limits
############################################
LLM_RPM=30
LLM_TPM=60000


############################################
# Response / Prompt Growth Controls
############################################
LLM_MAX_OUTPUT_TOKENS=512
LLM_MAX_HISTORY_MESSAGES=40
LLM_MAX_TOOL_OUTPUT_CHARS=8000


############################################
# Backoff Policy
############################################
LLM_BACKOFF_BASE_MS=1000
LLM_BACKOFF_MAX_MS=30000
LLM_BACKOFF_JITTER_MS=250
LLM_CIRCUIT_BREAKER_AFTER=6
LLM_CIRCUIT_BREAKER_OPEN_MS=60000


############################################
# Infrastructure
############################################
MCP_CALL_TIMEOUT_S=30
MAX_ARCHIVE_FILES=200
LN_BIND_HOST=127.0.0.1
LN_ANNOUNCE_HOST=127.0.0.1
UI_HOST=127.0.0.1
UI_PORT=8008


############################################
# Security (run scripts/setup_security.sh to configure)
############################################
# Admin password hash (PBKDF2-SHA256). Generated by setup_security.sh.
# When set, all API endpoints require a valid session cookie.
# Leave unset or empty to disable auth (backward compatible).
# UI_ADMIN_PASSWORD_HASH=

# Read-only viewer password hash (optional). Viewers can see data but
# cannot submit prompts, change config, or run system commands.
# UI_VIEWER_PASSWORD_HASH=

# Random secret for signing session cookies (32-byte hex string).
# Generated by setup_security.sh. Required when auth is enabled.
# UI_SESSION_SECRET=

# Session lifetime in seconds (default 3600 = 1 hour)
# UI_SESSION_TTL_S=3600

# TLS certificate and key paths. When both are set, the UI server
# runs HTTPS. Generate a self-signed cert with scripts/generate_cert.sh.
# UI_TLS_CERT=
# UI_TLS_KEY=

# CORS allowed origin. When set, only this origin can make cross-origin
# requests. When empty/unset, CORS headers are omitted (same-origin only).
# Use "*" only for development — never in production.
# UI_CORS_ORIGIN=


############################################
# x402 Payment Gateway
############################################
# Set X402_ENABLED=1 to gate selected API endpoints behind Lightning payments.
# Clients receive a 402 response with a BOLT11 invoice, pay it, and retry
# with the payment preimage in the X-Payment-Preimage header.
# X402_ENABLED=0

# Lightning node used to create x402 invoices (default: node 1)
# X402_INVOICE_NODE=1

# Invoice expiry in seconds (default: 600 = 10 minutes)
# X402_INVOICE_EXPIRY_S=600

# Per-endpoint prices in millisatoshis. Only set the ones you want to paywall.
# X402_ASK_COST_MSAT=1000000
# X402_NETWORK_COST_MSAT=100000
# X402_TRACE_COST_MSAT=50000

# Executor auto-pay: when enabled, the AI pipeline automatically pays 402
# invoices from external services and retries the tool call.
# EXECUTOR_X402_AUTO_PAY=0
# EXECUTOR_X402_PAY_NODE=2
# EXECUTOR_X402_MAX_AMOUNT_MSAT=100000000

# Approval threshold: payments above this amount (in msat) require human
# approval via the web UI. Payments below are auto-paid silently.
# Payments above MAX_AMOUNT_MSAT are always refused.
# X402_APPROVAL_THRESHOLD_MSAT=50000000
# X402_APPROVAL_TIMEOUT_S=120
