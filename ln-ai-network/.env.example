# ==============================================================
# ln-ai-network — Environment Template (SAFE TO COMMIT)
#
# ✅ Commit THIS file to Git as ".env.example"
# ❌ Do NOT commit a real ".env" (it will contain secrets)
#
# Setup for each developer:
#   cp .env.example .env
#   # edit .env and set secrets (OpenAI key, etc)
#
# Then load vars (from repo root):
#   source env.sh
#
# Notes:
# - env.sh will automatically source ".env" if it exists
# - Keep your real key only in your local ".env"
# ==============================================================


############################################
# LLM Provider Selection
############################################
# Supported:
#   - openai  (cloud, requires OPENAI_API_KEY)
#   - ollama  (local, no API key)
#   - gemini  (cloud, requires GEMINI_API_KEY)
#
# Gate to enable ANY LLM usage (local or cloud).
# For OpenAI/Gemini this also implies paid API usage, so keep it off unless needed.
ALLOW_LLM=1
LLM_PROVIDER=openai


############################################
# OpenAI Settings (Adapter-Specific)
############################################
# IMPORTANT: Replace with your real key in your local ".env"
# Example: OPENAI_API_KEY=sk-********************************
OPENAI_API_KEY=__REPLACE_WITH_REAL_KEY__

# Model name used by the OpenAI adapter
OPENAI_MODEL=gpt-4o

# Request timeout (seconds)
OPENAI_TIMEOUT_S=60


############################################
# Gemini Settings (Adapter-Specific)
############################################
# IMPORTANT: Replace with your real key in your local ".env"
GEMINI_API_KEY=__REPLACE_WITH_REAL_KEY__

# Model name (see https://ai.google.dev/gemini-api/docs/models)
GEMINI_MODEL=gemini-2.5-flash

# Request timeout (seconds)
GEMINI_TIMEOUT_S=180


############################################
# Ollama Settings (Adapter-Specific, Local)
############################################
# Ollama default local endpoint
# If Ollama is running on Windows and your code is in WSL, you may need to
# change this to the Windows host IP (not 127.0.0.1).
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Local model name (must be pulled via: ollama pull <model>)
# Examples:
#   llama3.2:3b
#   llama3.1:8b
OLLAMA_MODEL=llama3.2:3b

# Request timeout (seconds)
OLLAMA_TIMEOUT_SEC=120


############################################
# Pipeline Stage Overrides
############################################
# Each stage (translator/planner/executor) can use a different LLM backend
# and model. If not set, falls back to LLM_BACKEND / LLM_PROVIDER defaults.

# Backend per stage (openai | ollama | gemini)
# TRANSLATOR_LLM_BACKEND=openai
# PLANNER_LLM_BACKEND=openai
# EXECUTOR_DEFAULT_ON_ERROR=abort

# Model per stage (overrides OPENAI_MODEL / OLLAMA_MODEL / GEMINI_MODEL for that stage)
# TRANSLATOR_OPENAI_MODEL=gpt-4o-mini
# PLANNER_OPENAI_MODEL=gpt-4o
# TRANSLATOR_OLLAMA_MODEL=llama3.2:3b
# PLANNER_OLLAMA_MODEL=llama3.1:8b
# TRANSLATOR_GEMINI_MODEL=gemini-2.5-flash
# PLANNER_GEMINI_MODEL=gemini-2.5-flash

# Token / temperature tuning per stage
# TRANSLATOR_MAX_OUTPUT_TOKENS=512
# TRANSLATOR_TEMPERATURE=0.1
# TRANSLATOR_MAX_RETRIES=2
# PLANNER_MAX_OUTPUT_TOKENS=1024
# PLANNER_TEMPERATURE=0.1
# PLANNER_MAX_RETRIES=2


############################################
# Web UI Server
############################################
# Host and port for the agent web UI (scripts/ui_server.py)
# Accessible at http://UI_HOST:UI_PORT after running: python -m scripts.ui_server
UI_HOST=127.0.0.1
UI_PORT=8008


############################################
# Agent Cadence / Control Plane
############################################
# Deterministic tick cadence (ms). Agent "wakes up" on this schedule.
AGENT_TICK_MS=500

# Hard minimum time between LLM requests (ms), even if RPM/TPM allow more
LLM_MIN_INTERVAL_MS=1000

# Max concurrent in-flight LLM requests per agent process (keep 1 for determinism)
LLM_MAX_IN_FLIGHT=1


############################################
# Rate Limits (Set to your allocation)
############################################
# Requests Per Minute limit for the backend allocation used by this agent
# (For Ollama, these can be left as-is; they still act as safety caps.)
LLM_RPM=30

# Tokens Per Minute limit for the backend allocation used by this agent
LLM_TPM=60000


############################################
# Response / Prompt Growth Controls
############################################
# Max tokens the model is allowed to generate per call
LLM_MAX_OUTPUT_TOKENS=512

# Caps message history to prevent token runaway (system + last N-1 messages)
LLM_MAX_HISTORY_MESSAGES=40

# Caps tool output stored in history to avoid gigantic prompts
LLM_MAX_TOOL_OUTPUT_CHARS=8000


############################################
# Backoff Policy (Deterministic)
############################################
# Base backoff delay (ms) for transient errors / rate limits
LLM_BACKOFF_BASE_MS=1000

# Maximum backoff delay (ms)
LLM_BACKOFF_MAX_MS=30000

# Deterministic jitter window (ms) — derived from step id (NOT random)
LLM_BACKOFF_JITTER_MS=250

# Circuit breaker opens after N consecutive failures
LLM_CIRCUIT_BREAKER_AFTER=6

# Circuit breaker open duration (ms)
LLM_CIRCUIT_BREAKER_OPEN_MS=60000